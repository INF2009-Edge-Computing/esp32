# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.
# This file is used by the Python helper scripts (trigger_collect.py, testlog.py).
# ESP32 firmware credentials are configured via 'idf.py menuconfig' (see Kconfig.projbuild).

# MQTT broker address (Pi's IP or hostname on the same network)
MQTT_BROKER=192.168.0.x
MQTT_PORT=1883

# Rack / node identifier — must match ESP32_ID in firmware
RACK_ID=RACK_1

# Pi HTTP ingest server
HTTP_SERVER_BASE=http://192.168.0.x:5000
